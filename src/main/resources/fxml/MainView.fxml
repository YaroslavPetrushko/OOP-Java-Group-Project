<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.library.controller.MainController">

    <!-- ── Top bar ─────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="top-bar" spacing="12" alignment="CENTER_LEFT">
            <Label text="📚 Library Management System" styleClass="app-title"/>
        </HBox>
    </top>

    <!-- ── Centre: TabPane ─────────────────────────────────────── -->
    <center>
        <TabPane fx:id="tabPane"
                 tabClosingPolicy="UNAVAILABLE"
                 styleClass="main-tab-pane">

            <!-- ════ Books ════ -->
            <Tab text="Books" fx:id="booksTab">
                <VBox styleClass="tab-content">

                    <!-- Toolbar -->
                    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
                        <Button text="＋ Add"    styleClass="btn-primary"   onAction="#onAddBook"/>
                        <Button text="✎ Edit"   styleClass="btn-secondary" onAction="#onEditBook"/>
                        <Button text="✕ Delete" styleClass="btn-danger"    onAction="#onDeleteBook"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="bookSearchField"
                                   promptText="Search by title or author…"
                                   styleClass="search-field"
                                   prefWidth="240"/>
                    </HBox>

                    <!-- Filter bar -->
                    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
                        <Label text="Genre:" styleClass="filter-label"/>
                        <ComboBox fx:id="bookGenreFilter"
                                  promptText="All genres"
                                  prefWidth="150"/>
                        <Label text="Year:" styleClass="filter-label"/>
                        <TextField fx:id="bookYearFrom"
                                   promptText="From"
                                   prefWidth="70"
                                   styleClass="filter-field"/>
                        <Label text="—" styleClass="filter-label"/>
                        <TextField fx:id="bookYearTo"
                                   promptText="To"
                                   prefWidth="70"
                                   styleClass="filter-field"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✕ Clear filters"
                                styleClass="btn-clear"
                                onAction="#onClearBooksFilter"/>
                    </HBox>

                    <TableView fx:id="booksTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="bookIdCol"     text="ID"      prefWidth="50"  minWidth="40"/>
                            <TableColumn fx:id="bookTitleCol"  text="Title"   prefWidth="230" minWidth="120"/>
                            <TableColumn fx:id="bookAuthorCol" text="Author"  prefWidth="170" minWidth="100"/>
                            <TableColumn fx:id="bookGenreCol"  text="Genre"   prefWidth="120" minWidth="80"/>
                            <TableColumn fx:id="bookIsbnCol"   text="ISBN"    prefWidth="145" minWidth="100"/>
                            <TableColumn fx:id="bookYearCol"   text="Year"    prefWidth="65"  minWidth="50"/>
                            <TableColumn fx:id="bookCopiesCol" text="Copies"  prefWidth="65"  minWidth="50"/>
                        </columns>
                        <placeholder>
                            <Label text="No books found." styleClass="placeholder-text"/>
                        </placeholder>
                    </TableView>

                </VBox>
            </Tab>

            <!-- ════ Authors ════ -->
            <Tab text="Authors" fx:id="authorsTab">
                <VBox styleClass="tab-content">

                    <!-- Toolbar -->
                    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
                        <Button text="＋ Add"    styleClass="btn-primary"   onAction="#onAddAuthor"/>
                        <Button text="✎ Edit"   styleClass="btn-secondary" onAction="#onEditAuthor"/>
                        <Button text="✕ Delete" styleClass="btn-danger"    onAction="#onDeleteAuthor"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="authorSearchField"
                                   promptText="Search by name, country or year…"
                                   styleClass="search-field"
                                   prefWidth="260"/>
                    </HBox>

                    <!-- Filter bar -->
                    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
                        <Label text="Country:" styleClass="filter-label"/>
                        <ComboBox fx:id="authorCountryFilter"
                                  promptText="All countries"
                                  prefWidth="165"/>
                        <Label text="Birth year:" styleClass="filter-label"/>
                        <TextField fx:id="authorYearFrom"
                                   promptText="From"
                                   prefWidth="70"
                                   styleClass="filter-field"/>
                        <Label text="—" styleClass="filter-label"/>
                        <TextField fx:id="authorYearTo"
                                   promptText="To"
                                   prefWidth="70"
                                   styleClass="filter-field"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✕ Clear filters"
                                styleClass="btn-clear"
                                onAction="#onClearAuthorsFilter"/>
                    </HBox>

                    <TableView fx:id="authorsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="authorIdCol"        text="ID"         prefWidth="50"  minWidth="40"/>
                            <TableColumn fx:id="authorNameCol"      text="Full Name"  prefWidth="240" minWidth="120"/>
                            <TableColumn fx:id="authorCountryCol"   text="Country"    prefWidth="160" minWidth="80"/>
                            <TableColumn fx:id="authorBirthYearCol" text="Birth Year" prefWidth="100" minWidth="70"/>
                        </columns>
                        <placeholder>
                            <Label text="No authors found." styleClass="placeholder-text"/>
                        </placeholder>
                    </TableView>

                </VBox>
            </Tab>

            <!-- ════ Readers ════ -->
            <Tab text="Readers" fx:id="readersTab">
                <VBox styleClass="tab-content">

                    <!-- Toolbar -->
                    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
                        <Button text="＋ Add"    styleClass="btn-primary"   onAction="#onAddReader"/>
                        <Button text="✎ Edit"   styleClass="btn-secondary" onAction="#onEditReader"/>
                        <Button text="✕ Delete" styleClass="btn-danger"    onAction="#onDeleteReader"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="readerSearchField"
                                   promptText="Search by name, email or phone…"
                                   styleClass="search-field"
                                   prefWidth="260"/>
                    </HBox>

                    <!-- Filter bar -->
                    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
                        <Label text="Registered:" styleClass="filter-label"/>
                        <DatePicker fx:id="readerRegFrom"
                                    promptText="From"
                                    prefWidth="145"/>
                        <Label text="—" styleClass="filter-label"/>
                        <DatePicker fx:id="readerRegTo"
                                    promptText="To"
                                    prefWidth="145"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✕ Clear filters"
                                styleClass="btn-clear"
                                onAction="#onClearReadersFilter"/>
                    </HBox>

                    <TableView fx:id="readersTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="readerIdCol"      text="ID"         prefWidth="50"  minWidth="40"/>
                            <TableColumn fx:id="readerNameCol"    text="Full Name"  prefWidth="190" minWidth="120"/>
                            <TableColumn fx:id="readerEmailCol"   text="Email"      prefWidth="190" minWidth="120"/>
                            <TableColumn fx:id="readerPhoneCol"   text="Phone"      prefWidth="130" minWidth="90"/>
                            <TableColumn fx:id="readerRegDateCol" text="Registered" prefWidth="110" minWidth="80"/>
                        </columns>
                        <placeholder>
                            <Label text="No readers found." styleClass="placeholder-text"/>
                        </placeholder>
                    </TableView>

                </VBox>
            </Tab>

            <!-- ════ Loans ════ -->
            <Tab text="Loans" fx:id="loansTab">
                <VBox styleClass="tab-content">

                    <!-- Toolbar -->
                    <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
                        <Button text="＋ Add"    styleClass="btn-primary"   onAction="#onAddLoan"/>
                        <Button text="✎ Edit"   styleClass="btn-secondary" onAction="#onEditLoan"/>
                        <Button text="✕ Delete" styleClass="btn-danger"    onAction="#onDeleteLoan"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="loanSearchField"
                                   promptText="Search by ID, book or reader…"
                                   styleClass="search-field"
                                   prefWidth="260"/>
                    </HBox>

                    <!-- Filter bar -->
                    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
                        <Label text="Status:" styleClass="filter-label"/>
                        <ComboBox fx:id="loanStatusFilter"
                                  promptText="All statuses"
                                  prefWidth="140"/>
                        <Label text="Loan date:" styleClass="filter-label"/>
                        <DatePicker fx:id="loanDateFrom"
                                    promptText="From"
                                    prefWidth="145"/>
                        <Label text="—" styleClass="filter-label"/>
                        <DatePicker fx:id="loanDateTo"
                                    promptText="To"
                                    prefWidth="145"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✕ Clear filters"
                                styleClass="btn-clear"
                                onAction="#onClearLoansFilter"/>
                    </HBox>

                    <TableView fx:id="loansTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="loanIdCol"     text="ID"        prefWidth="50"  minWidth="40"/>
                            <TableColumn fx:id="loanBookCol"   text="Book"      prefWidth="210" minWidth="120"/>
                            <TableColumn fx:id="loanReaderCol" text="Reader"    prefWidth="170" minWidth="100"/>
                            <TableColumn fx:id="loanDateCol"   text="Loan Date" prefWidth="105" minWidth="80"/>
                            <TableColumn fx:id="loanDueCol"    text="Due Date"  prefWidth="105" minWidth="80"/>
                            <TableColumn fx:id="loanStatusCol" text="Status"    prefWidth="90"  minWidth="70"/>
                        </columns>
                        <placeholder>
                            <Label text="No loans found." styleClass="placeholder-text"/>
                        </placeholder>
                    </TableView>

                </VBox>
            </Tab>

        </TabPane>
    </center>

    <!-- ── Status bar ──────────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
            <Label fx:id="statusLabel" styleClass="status-label"/>
        </HBox>
    </bottom>

</BorderPane>
